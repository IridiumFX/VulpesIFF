/* VulpesIFF — `now` build manifest.
 *
 * Layout (post-Maven conversion 2026-05-15):
 *   src/main/c/                   34 IFF .c files (auto-discovered)
 *   src/test/c/                   53 entries: tests + harness + CMakeLists
 *   include/IFF/                  public headers
 *   Codecs/{ILBM,SVX8}/           codec .c + .h, kept at repo root
 *   Codecs/demo_codecs.c          CLI exe (excluded from this artifact)
 *   dependencies/VulpesCore/      submodule, also Maven layout
 *     src/main/c/VPS_*.c          16 foundation .c files
 *     include/vulpes/             public headers
 */
{
  group:    "dev.iridium",
  artifact: "vulpes-iff",
  version:  "1.0.0",
  description: "VulpesIFF — IFF-2025 reference reader/writer with ILBM + SVX8 codecs",
  license:  "MIT",
  lang:     "c",
  std:      "c23",

  sources: {
    headers: "include",
    include: [
      "Codecs/ILBM/ILBM_Codec.c",
      "Codecs/ILBM/ILBM_Conversion.c",
      "Codecs/ILBM/ILBM_Decompression.c",
      "Codecs/ILBM/ILBM_Loader.c",
      "Codecs/SVX8/SVX8_Codec.c",
      "Codecs/SVX8/SVX8_Decompression.c",
      "Codecs/SVX8/SVX8_Loader.c",
      "dependencies/VulpesCore/src/main/c/VPS_Compare_Utils.c",
      "dependencies/VulpesCore/src/main/c/VPS_ConcurrentDictionary.c",
      "dependencies/VulpesCore/src/main/c/VPS_Data.c",
      "dependencies/VulpesCore/src/main/c/VPS_DataReader.c",
      "dependencies/VulpesCore/src/main/c/VPS_DataWriter.c",
      "dependencies/VulpesCore/src/main/c/VPS_Decoder.c",
      "dependencies/VulpesCore/src/main/c/VPS_Decoder_Base256.c",
      "dependencies/VulpesCore/src/main/c/VPS_Dictionary.c",
      "dependencies/VulpesCore/src/main/c/VPS_Endian.c",
      "dependencies/VulpesCore/src/main/c/VPS_Hash_Utils.c",
      "dependencies/VulpesCore/src/main/c/VPS_List.c",
      "dependencies/VulpesCore/src/main/c/VPS_ScopedDictionary.c",
      "dependencies/VulpesCore/src/main/c/VPS_Set.c",
      "dependencies/VulpesCore/src/main/c/VPS_StreamReader.c",
      "dependencies/VulpesCore/src/main/c/VPS_StreamWriter.c",
      "dependencies/VulpesCore/src/main/c/VPS_SwissDictionary.c"
    ]
  },

  output: { type: "static", name: "vulpes_iff" },

  compile: {
    warnings: ["Wall", "Wextra"],
    includes: [
      "include",
      "src",
      "Codecs",
      "dependencies/VulpesCore/include",
      "dependencies/VulpesCore/src/main/c"
    ],
    defines: []
  }
}
